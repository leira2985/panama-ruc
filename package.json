{
  "name": "@workflow507/panama-ruc",
  "version": "0.2.0",
  "description": "Motor ultra rápido de cálculo y validación del Dígito Verificador (DV) del RUC en Panamá. Sin dependencias. Funciona en Node, Bun, Deno, Cloudflare Workers y navegadores.",
  "keywords": [
    "panama",
    "ruc",
    "dv",
    "digito-verificador",
    "dgi",
    "factura-electronica",
    "sfep",
    "cedula",
    "tributario",
    "contabilidad",
    "workflow507"
  ],
  "homepage": "https://github.com/leira2985/panama-ruc#readme",
  "bugs": {
    "url": "https://github.com/leira2985/panama-ruc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leira2985/panama-ruc.git"
  },
  "license": "MIT",
  "author": {
    "name": "Jeziel Leira",
    "email": "jeziel@workflow507.com",
    "url": "https://workflow507.com"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "panama-ruc": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "release": "npm publish --access public"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
